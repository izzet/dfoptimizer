{
  "objective": "maximize",
  "metrics": {
    "samples_per_sec": {
      "direction": "maximize",
      "weight": 1.0
    },
    "gpu_idle_frac": {
      "direction": "minimize",
      "weight": 500.0
    },
    "epoch_time_sec": {
      "direction": "minimize",
      "weight": 50.0
    }
  },
  "hard_constraints": {
    "oom_count": {
      "max": 0
    },
    "error_count": {
      "max": 0
    }
  },
  "normalization": {
    "samples_per_sec": {
      "method": "robust",
      "p_low": 5,
      "p_high": 95
    },
    "epoch_time_sec": {
      "method": "robust",
      "p_low": 5,
      "p_high": 95
    },
    "gpu_idle_frac": {
      "method": "clip",
      "min": 0.0,
      "max": 1.0
    }
  }
}